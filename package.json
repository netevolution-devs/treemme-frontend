{
  "name": "netevo-default-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/style": "^0.8.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/x-date-pickers": "^8.27.0",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-query-devtools": "^5.91.2",
    "axios": "^1.13.2",
    "dayjs": "^1.11.13",
    "dockview": "^5.0.0",
    "i18next": "^25.8.5",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "immer": "^11.1.4",
    "material-react-table": "^3.2.1",
    "material-ui-popup-state": "^5.3.6",
    "mui-one-time-password-input": "^5.0.0",
    "notistack": "^3.0.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^15.4.0",
    "react-router": "^7.12.0",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "dev": "vite",
    "build:production": "tsc -b --noEmit && vite build --mode production",
    "build:staging": "tsc -b --noEmit && vite build --mode staging",
    "build:local": "tsc -b --noEmit && vite build --mode development",
    "build:local:force": "vite build --mode development",
    "preview": "vite preview",
    "dev:default": "vite --open /app-default.html",
    "build:default:production": "set BUILD_TARGET=default&& npm run typecheck && vite build --mode production",
    "build:default:staging": "set BUILD_TARGET=default&& npm run typecheck && vite build --mode staging",
    "build:default:local": "set BUILD_TARGET=default&& npm run typecheck && vite build --mode development",
    "preview:default": "vite preview --open /app-default.html",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1"
  }
}
